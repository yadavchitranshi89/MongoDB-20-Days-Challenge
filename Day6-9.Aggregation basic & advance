// ADVANCED AGGREGATION STAGES

//41. Use $lookup to join employees with departments collection
db.employees.aggregate([
{
 $lookup:{
   from:"departments",
   localField:"departmentId",
   foreignField:"_id",
   as:"departmentDetails"
 }
}
])

//42. Use $graphLookup to find employee hierarchy
db.employees.aggregate([
{
 $graphLookup:{
   from:"employees",
   startWith:"$managerId",
   connectFromField:"managerId",
   connectToField:"_id",
   as:"hierarchy"
 }
}
])

//43.  Use $facet to get high salary and low salary employees together
db.employees.aggregate([
{
 $facet:{
   highSalary:[
     {$match:{salary:{$gt:50000}}}
   ],
   lowSalary:[
     {$match:{salary:{$lte:50000}}}
   ]
 }
}
])

//44. Use $bucket to group employees by age ranges
db.employees.aggregate([
{
 $bucket:{
   groupBy:"$age",
   boundaries:[20,25,30,35],
   default:"Other",
   output:{
     count:{$sum:1}
   }
 }
}
])

//45. Use $bucketAuto to create automatic salary groups
db.employees.aggregate([
{
 $bucketAuto:{
   groupBy:"$salary",
   buckets:3,
   output:{
     count:{$sum:1}
   }
 }
}
])

